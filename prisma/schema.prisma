generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"

}

model User {
  id               String            @id @default(uuid())
  email            String            @unique
  name             String?
  password         String?           // Added for NextAuth Credentials
  subscriptionTier      String            @default("FREE") // FREE, PRO, ELITE
  subscriptionStatus    String            @default("INACTIVE") // ACTIVE, INACTIVE
  subscriptionPeriodEnd DateTime?
  lastPaymentId         String?
  balance               Float             @default(100000) // Virtual balance for paper trading
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  watchlists            Watchlist[]
  chartLayouts          ChartLayout[]
  portfolios            Portfolio[]
  alerts                Alert[]
  posts                 Post[]
  comments              Comment[]
  payments              Payment[]
}

model Watchlist {
  id        String          @id @default(uuid())
  name      String
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     WatchlistItem[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([userId, name])
}

model WatchlistItem {
  id          String    @id @default(uuid())
  watchlistId String
  watchlist   Watchlist @relation(fields: [watchlistId], references: [id], onDelete: Cascade)
  symbol      String
  addedAt     DateTime  @default(now())

  @@unique([watchlistId, symbol])
}

model ChartLayout {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol       String
  layoutData   Json?    // For saving pane heights, visible ranges, etc.
  drawingsData Json?    // For saving trendlines, fibonacci, etc.
  updatedAt    DateTime @updatedAt

  @@unique([userId, symbol])
}

model Portfolio {
  id        String          @id @default(uuid())
  name      String
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     PortfolioItem[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model PortfolioItem {
  id           String    @id @default(uuid())
  portfolioId  String
  portfolio    Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  symbol       String
  quantity     Float
  averagePrice Float
  addedAt      DateTime  @default(now())

  @@unique([portfolioId, symbol])
}

model Alert {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol    String
  type      String   // PRICE_ABOVE, PRICE_BELOW, RSI_ABOVE, RSI_BELOW, VOLUME_ABOVE
  value     Float
  status    String   @default("ACTIVE") // ACTIVE, TRIGGERED, INACTIVE
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Post {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title      String
  content    String
  symbol     String?   // Tagged stock (e.g. 1120.SR)
  action     String?   // BUY, SELL, HOLD, EDUCATIONAL
  likesCount Int       @default(0)
  comments   Comment[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Comment {
  id        String   @id @default(uuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())
}

model Payment {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Float
  currency  String   @default("SAR")
  status    String   // paid, failed, initiated
  moyasarId String?  @unique
  tier      String   // PRO, ELITE
  period    String   // MONTHLY, YEARLY
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
